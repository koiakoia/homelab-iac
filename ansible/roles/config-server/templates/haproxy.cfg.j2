# {{ ansible_managed }}
# HAProxy configuration for OKD 4 Overwatch cluster
# NIST SC-7: Boundary Protection - load balancing

global
    log /dev/log local0
    log /dev/log local1 notice
    chroot /var/lib/haproxy
    stats socket /run/haproxy/admin.sock mode 660 level admin expose-fd listeners
    stats timeout 30s
    user haproxy
    group haproxy
    daemon

    # Default SSL material locations
    ca-base /etc/ssl/certs
    crt-base /etc/ssl/private

    # SSL Settings
    ssl-default-bind-ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305:DHE-RSA-AES128-GCM-SHA256:DHE-RSA-AES256-GCM-SHA384
    ssl-default-bind-ciphersuites TLS_AES_128_GCM_SHA256:TLS_AES_256_GCM_SHA384:TLS_CHACHA20_POLY1305_SHA256
    ssl-default-bind-options ssl-min-ver TLSv1.2 no-tls-tickets

defaults
    log     global
    mode    http
    option  httplog
    option  dontlognull
    timeout connect 5000
    timeout client  50000
    timeout server  50000
    errorfile 400 /etc/haproxy/errors/400.http
    errorfile 403 /etc/haproxy/errors/403.http
    errorfile 408 /etc/haproxy/errors/408.http
    errorfile 500 /etc/haproxy/errors/500.http
    errorfile 502 /etc/haproxy/errors/502.http
    errorfile 503 /etc/haproxy/errors/503.http
    errorfile 504 /etc/haproxy/errors/504.http

# ---------------------------------------------------------------------
# OKD 4 Overwatch Cluster Load Balancing
# ---------------------------------------------------------------------

# --- API Server ({{ haproxy_api_port }}) ---
frontend okd4_api_frontend
    bind *:{{ haproxy_api_port }}
    default_backend okd4_api_backend
    mode tcp
    option tcplog

backend okd4_api_backend
    balance roundrobin
    mode tcp
    # server bootstrap {{ okd_bootstrap_node.ip }}:{{ haproxy_api_port }} check  # Removed - bootstrap VM powered off
{% for master in okd_master_nodes %}
    server {{ master.name | replace('-', '') }}   {{ master.ip }}:{{ haproxy_api_port }} check
{% endfor %}

# --- Machine Config Server ({{ haproxy_machine_config_port }}) ---
frontend okd4_machine_config_frontend
    bind *:{{ haproxy_machine_config_port }}
    default_backend okd4_machine_config_backend
    mode tcp
    option tcplog

backend okd4_machine_config_backend
    balance roundrobin
    mode tcp
    # server bootstrap {{ okd_bootstrap_node.ip }}:{{ haproxy_machine_config_port }} check  # Removed - bootstrap VM powered off
{% for master in okd_master_nodes %}
    server {{ master.name | replace('-', '') }}   {{ master.ip }}:{{ haproxy_machine_config_port }} check
{% endfor %}

# --- Ingress HTTP ({{ haproxy_http_port }}) ---
frontend okd4_http_ingress_frontend
    bind *:{{ haproxy_http_port }}
    default_backend okd4_http_ingress_backend
    mode tcp
    option tcplog

backend okd4_http_ingress_backend
    balance roundrobin
    mode tcp
{% for master in okd_master_nodes %}
    server {{ master.name | replace('-', '') }} {{ master.ip }}:{{ haproxy_http_port }} check
{% endfor %}

# --- Ingress HTTPS ({{ haproxy_https_port }}) ---
frontend okd4_https_ingress_frontend
    bind *:{{ haproxy_https_port }}
    default_backend okd4_https_ingress_backend
    mode tcp
    option tcplog

backend okd4_https_ingress_backend
    balance roundrobin
    mode tcp
{% for master in okd_master_nodes %}
    server {{ master.name | replace('-', '') }} {{ master.ip }}:{{ haproxy_https_port }} check
{% endfor %}

# --- Statistics (Optional, internal only) ---
listen stats
    bind {{ haproxy_stats_bind }}
    mode http
    stats enable
    stats uri /
    stats hide-version
