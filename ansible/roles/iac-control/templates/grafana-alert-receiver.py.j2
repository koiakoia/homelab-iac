#!/usr/bin/env python3
# {{ ansible_managed }}
# Grafana Alert Webhook Receiver
# Listens on port {{ grafana_alert_port }} and logs incoming alerts

import json
import logging
from datetime import datetime
from http.server import HTTPServer, BaseHTTPRequestHandler

LOG_FILE = "{{ grafana_alert_log }}"
PORT = {{ grafana_alert_port }}

logging.basicConfig(
    filename=LOG_FILE,
    level=logging.INFO,
    format='%(asctime)s - %(levelname)s - %(message)s'
)


class AlertHandler(BaseHTTPRequestHandler):
    def do_POST(self):
        content_length = int(self.headers.get('Content-Length', 0))
        body = self.rfile.read(content_length)

        try:
            payload = json.loads(body)
            alerts = payload.get('alerts', [])

            for alert in alerts:
                status = alert.get('status', 'unknown')
                labels = alert.get('labels', {})
                annotations = alert.get('annotations', {})
                alertname = labels.get('alertname', 'unnamed')
                summary = annotations.get('summary', 'no summary')

                log_msg = f"[{status.upper()}] {alertname}: {summary}"
                logging.info(log_msg)

            self.send_response(200)
            self.send_header('Content-Type', 'application/json')
            self.end_headers()
            self.wfile.write(b'{"status": "ok"}')

        except json.JSONDecodeError:
            logging.error(f"Invalid JSON received: {body[:500]}")
            self.send_response(400)
            self.end_headers()
            self.wfile.write(b'{"error": "invalid json"}')

    def log_message(self, format, *args):
        # Suppress default HTTP log noise
        pass


if __name__ == '__main__':
    server = HTTPServer(('0.0.0.0', PORT), AlertHandler)
    logging.info(f"Grafana alert receiver started on port {PORT}")
    print(f"Listening on port {PORT}, logging to {LOG_FILE}")
    server.serve_forever()
