# {{ ansible_managed }}
# Sentinel Service Dashboard DNS - NIST SC-7(16)
# Resolves *.${INTERNAL_DOMAIN} locally to prevent public DNS topology leak
address=/.{{ sentinel_dns_domain }}/{{ sentinel_dns_target }}
# Resolve external-facing *.${DOMAIN} domains internally to avoid Cloudflare round-trip
address=/auth.${DOMAIN}/{{ sentinel_dns_target }}
address=/gitlab.${DOMAIN}/{{ sentinel_dns_target }}
address=/matrix.${DOMAIN}/{{ sentinel_dns_target }}
