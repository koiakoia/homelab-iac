# {{ ansible_managed }}
# iDRAC Redfish credentials for node recovery and health monitoring
# Sourced by idrac-node-recovery.sh, idrac-health-check.sh, idrac-watchdog.sh

{% for node in idrac_nodes %}
# {{ node.name }} — {{ node.model }} ({{ node.generation }})
IDRAC_{{ node.name | upper | regex_replace('-', '_') }}_USER="{{ node.idrac_user }}"
IDRAC_{{ node.name | upper | regex_replace('-', '_') }}_PASS="{{ node.idrac_pass }}"
{% endfor %}

# Watchdog configuration
IDRAC_WATCHDOG_FAIL_THRESHOLD={{ idrac_watchdog_fail_threshold }}
IDRAC_WATCHDOG_ENABLED={{ idrac_watchdog_enabled | lower }}
