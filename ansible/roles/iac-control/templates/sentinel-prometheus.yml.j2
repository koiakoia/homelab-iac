# {{ ansible_managed }}
global:
  scrape_interval: 30s
  evaluation_interval: 30s

scrape_configs:
  - job_name: unifi-exporter
    static_configs:
      - targets: ["127.0.0.1:{{ unifi_exporter_port }}"]
        labels:
          instance: iac-control

  - job_name: traefik
    static_configs:
      - targets: ["{{ prometheus_traefik_target }}"]
        labels:
          instance: pangolin-proxy

{% if prometheus_vault_enabled %}
  - job_name: vault
    scheme: https
    metrics_path: /v1/sys/metrics
    params:
      format: ["prometheus"]
    tls_config:
      insecure_skip_verify: true
{% if prometheus_vault_token is defined and prometheus_vault_token != 'CHANGE_ME' %}
    bearer_token: "{{ prometheus_vault_token }}"
{% endif %}
    static_configs:
      - targets: ["{{ prometheus_vault_target }}"]
        labels:
          instance: vault-server
{% endif %}

  - job_name: wazuh-vulnerabilities
    scrape_interval: 5m
    metrics_path: /metrics
    static_configs:
      - targets: ["{{ prometheus_wazuh_target }}"]
        labels:
          instance: wazuh-server
