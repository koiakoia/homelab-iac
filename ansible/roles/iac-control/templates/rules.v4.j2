# {{ ansible_managed }}
# iptables rules for iac-control - REFERENCE BACKUP ONLY
# Active firewall rules are managed via UFW (see /etc/ufw/before.rules)
# This file is kept for documentation and DR recovery purposes
# NIST SC-7: Boundary Protection - stateful firewall

*raw
:PREROUTING ACCEPT [0:0]
:OUTPUT ACCEPT [0:0]
COMMIT

*filter
:INPUT ACCEPT [0:0]
:FORWARD DROP [0:0]
:OUTPUT ACCEPT [0:0]
:DOCKER - [0:0]
:DOCKER-BRIDGE - [0:0]
:DOCKER-CT - [0:0]
:DOCKER-FORWARD - [0:0]
:DOCKER-ISOLATION-STAGE-1 - [0:0]
:DOCKER-ISOLATION-STAGE-2 - [0:0]
:DOCKER-USER - [0:0]

# --- INPUT Chain Rules ---
# Allow established/related connections
-A INPUT -m state --state RELATED,ESTABLISHED -j ACCEPT

# Allow loopback
-A INPUT -i lo -j ACCEPT

# Allow SSH
-A INPUT -p tcp -m tcp --dport 22 -j ACCEPT

# Allow DNS on OKD interface
-A INPUT -i {{ okd_interface }} -p udp -m udp --dport 53 -j ACCEPT
-A INPUT -i {{ okd_interface }} -p tcp -m tcp --dport 53 -j ACCEPT

# Allow DNS from LAN clients (SC-7(16) local DNS)
-A INPUT -s {{ management_network }} -p udp -m udp --dport 53 -j ACCEPT
-A INPUT -s {{ management_network }} -p tcp -m tcp --dport 53 -j ACCEPT

# RPC portmapper protection - localhost only
-A INPUT -s 127.0.0.1/32 -p tcp -m tcp --dport 111 -j ACCEPT
-A INPUT -s 127.0.0.1/32 -p udp -m udp --dport 111 -j ACCEPT
-A INPUT -p tcp -m tcp --dport 111 -j DROP
-A INPUT -p udp -m udp --dport 111 -j DROP

# HAProxy access control
{% for source in haproxy_allowed_sources %}
-A INPUT -s {{ source }} -p tcp -m multiport --dports 80,443,6443,22623 -j ACCEPT
{% endfor %}
-A INPUT -i {{ okd_interface }} -p tcp -m multiport --dports 80,443,6443,22623 -j ACCEPT

# Log and drop blocked HAProxy attempts
{% if enable_iptables_logging %}
-A INPUT -p tcp -m multiport --dports 80,443,6443,22623,9000 -j LOG --log-prefix "HAPROXY-BLOCK: "
{% endif %}
-A INPUT -p tcp -m multiport --dports 80,443,6443,22623,9000 -j DROP

# --- FORWARD Chain Rules ---
-A FORWARD -j DOCKER-USER
-A FORWARD -j DOCKER-FORWARD

# DNS forwarding (Cloudflare, Google)
-A FORWARD -d 1.1.1.1/32 -i {{ okd_interface }} -o {{ primary_interface }} -p udp -m udp --dport 53 -j ACCEPT
-A FORWARD -d 8.8.8.8/32 -i {{ okd_interface }} -o {{ primary_interface }} -p udp -m udp --dport 53 -j ACCEPT

# NTP forwarding
-A FORWARD -i {{ okd_interface }} -o {{ primary_interface }} -p udp -m udp --dport 123 -j ACCEPT

# HTTP + HTTPS forwarding for container image pulls and health checks
-A FORWARD -i {{ okd_interface }} -o {{ primary_interface }} -p tcp -m tcp --dport 443 -j ACCEPT
-A FORWARD -i {{ okd_interface }} -o {{ primary_interface }} -p tcp -m tcp --dport 80 -j ACCEPT

# SMTP forwarding for email (Mailjet)
-A FORWARD -i {{ okd_interface }} -o {{ primary_interface }} -p tcp -m tcp --dport 587 -j ACCEPT

# NFS access to storage server (TCP + UDP)
-A FORWARD -d {{ nfs_server }}/32 -i {{ okd_interface }} -o {{ primary_interface }} -p tcp -m multiport --dports 2049,111 -j ACCEPT
-A FORWARD -d {{ nfs_server }}/32 -i {{ okd_interface }} -o {{ primary_interface }} -p udp -m multiport --dports 2049,111 -j ACCEPT

# ICMP forwarding
-A FORWARD -i {{ okd_interface }} -o {{ primary_interface }} -p icmp -j ACCEPT

# WireGuard forwarding (if applicable)
-A FORWARD -i {{ okd_interface }} -o {{ primary_interface }} -p udp -m udp --dport 21820 -j ACCEPT
-A FORWARD -i {{ okd_interface }} -o {{ primary_interface }} -p udp -m udp --dport 51820 -j ACCEPT

# MinIO access
-A FORWARD -d {{ minio_server }}/32 -i {{ okd_interface }} -o {{ primary_interface }} -p tcp -m tcp --dport 9000 -j ACCEPT

# GitLab access
-A FORWARD -d {{ gitlab_server }}/32 -i {{ okd_interface }} -o {{ primary_interface }} -p tcp -m multiport --dports 22,80,443 -j ACCEPT

# Return traffic
-A FORWARD -i {{ primary_interface }} -o {{ okd_interface }} -m conntrack --ctstate RELATED,ESTABLISHED -j ACCEPT

# Log and drop all other egress attempts
{% if enable_iptables_logging %}
-A FORWARD -i {{ okd_interface }} -o {{ primary_interface }} -j LOG --log-prefix "OKD-EGRESS-DENY: "
{% endif %}
-A FORWARD -i {{ okd_interface }} -o {{ primary_interface }} -j DROP

# --- Docker Chain Rules ---
-A DOCKER ! -i docker0 -o docker0 -j DROP
-A DOCKER-BRIDGE -o docker0 -j DOCKER
-A DOCKER-CT -o docker0 -m conntrack --ctstate RELATED,ESTABLISHED -j ACCEPT
-A DOCKER-FORWARD -j DOCKER-CT
-A DOCKER-FORWARD -j DOCKER-ISOLATION-STAGE-1
-A DOCKER-FORWARD -j DOCKER-BRIDGE
-A DOCKER-FORWARD -i docker0 -j ACCEPT
-A DOCKER-ISOLATION-STAGE-1 -i docker0 ! -o docker0 -j DOCKER-ISOLATION-STAGE-2
-A DOCKER-ISOLATION-STAGE-2 -o docker0 -j DROP
COMMIT

*nat
:PREROUTING ACCEPT [0:0]
:INPUT ACCEPT [0:0]
:OUTPUT ACCEPT [0:0]
:POSTROUTING ACCEPT [0:0]
:DOCKER - [0:0]

# Allow traffic within management network
-A PREROUTING -d {{ management_network }} -i {{ okd_interface }} -j ACCEPT

# Docker NAT setup
-A PREROUTING -m addrtype --dst-type LOCAL -j DOCKER

-A OUTPUT ! -d 127.0.0.0/8 -m addrtype --dst-type LOCAL -j DOCKER

# Docker masquerading
-A POSTROUTING -s 172.17.0.0/16 ! -o docker0 -j MASQUERADE

# OKD cluster network masquerading
-A POSTROUTING -s {{ okd_network }} -o {{ primary_interface }} -j MASQUERADE

-A DOCKER -i docker0 -j RETURN
COMMIT
